---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = [
  {
    title: 'Aninaya — Local-first Personal Finance',
    description: 'Consumer Android app for Filipinos. On-device AI receipt OCR (ML Kit + Qwen 2.5 / SmolLM), SALN module for government employees with CSC-template DOCX/PDF export, AI Planner with optional Bring-Your-Own AI endpoint, encrypted vault export (AES-256-GCM), and Aninaya Bridge for phone-to-phone LAN sync. AES-256 SQLCipher database. Published on Google Play.',
    tags: ['Flutter', 'Drift', 'Riverpod', 'Qwen 2.5', 'SQLCipher', 'On-device AI', 'Android', 'Play Store'],
    iconUrl: '/aninaya/icon.png',
    infoUrl: '/aninaya/',
  },
  {
    title: 'IDP System — Intelligent Document Processing',
    description: 'Enterprise RAG-based document extraction engine with parallel batch processing (14-step pipeline), multi-provider AI support (Ollama, OpenAI, Anthropic, Gemini, Groq), Human-in-the-Loop review workflows with active learning, and multi-tenant RBAC. In a production proof-of-concept it reached 99.95% cell-level and 99.40% row-level extraction accuracy across ~22,000 fields on structured government enrollment forms. Deployed internally at DSWD Philippines.',
    tags: ['Python', 'FastAPI', 'React', 'PostgreSQL', 'pgvector', 'Redis', 'MinIO', 'Ollama', 'Docker'],
    demoUrl: '/demos',
  },
  {
    title: 'Atlas — Personal AI Assistant',
    description: 'Voice + text multi-agent orchestrator with a 3-ring, offline-first architecture. Local wake-word ("hey atlas") via openWakeWord, faster-whisper STT and Piper TTS, with on-device Ollama models for intent routing and a Claude/Gemini cloud tier for hard reasoning. Retrieval over a personal vault and diary using sqlite-vec, plus a JARVIS-style HUD built with FastAPI + HTMX.',
    tags: ['Python', 'Ollama', 'faster-whisper', 'Piper', 'sqlite-vec', 'FastAPI', 'HTMX'],
  },
  {
    title: 'Lo-CADIS Sprout — IoT Location & Asset Tracking',
    description: 'Real-time IoT monitoring platform with MQTT ingestion, ESP32/Wemos firmware, TimescaleDB time-series storage, automated alerting, and multi-tenant farm management. Originated at UPLB (2018-2019), revived and modernized.',
    tags: ['FastAPI', 'React', 'MQTT', 'ESP32', 'TimescaleDB', 'Celery', 'Docker'],
    repoUrl: 'https://github.com/KaijuBytes/locadis',
  },
  {
    title: 'Reporting Automation Pipeline',
    description: 'Document-automation pipeline for semi-monthly government reporting. Converts Markdown + YAML frontmatter into submission-ready Word, PDF, and Google Docs output via direct python-docx / OOXML editing — reproducing official templates faithfully (column widths, merged headers, signature blocks, live page fields). Multi-format export with a guided CLI wizard.',
    tags: ['Python', 'python-docx', 'OOXML', 'Google Docs API', 'CLI'],
  },
  {
    title: 'Aninaya Tax Companion',
    description: 'Local-first Flutter BIR tax estimator for Philippine freelancers and mixed-income earners. 8% vs graduated tax comparison, 1701Q quarterly worksheet, and a BIR deadline tracker — sharing an on-device data core with the Aninaya finance app so figures never need re-entry. In development.',
    tags: ['Flutter', 'Dart', 'Riverpod', 'Drift', 'SQLCipher', 'On-device'],
  },
  {
    title: 'Aninaya Automations',
    description: 'Privacy-first n8n automation companion for Aninaya. Uses a pull model over a secure HTTPS GET endpoint (not inbound push) to ingest transactions from email, keeping credentials and data under the user’s control. MIT-licensed.',
    tags: ['n8n', 'Docker', 'Gmail API', 'Automation'],
    repoUrl: 'https://github.com/KaijuBytes/aninaya-automations',
  },
  {
    title: 'Business Lookup AI',
    description: 'Local LLM-powered assistant for business search. Uses Ollama for on-prem inference with FAISS vector similarity search. Demonstrates data sovereignty and zero-cost AI inference.',
    tags: ['Python', 'Ollama', 'FAISS', 'LLM'],
    repoUrl: 'https://github.com/KaijuBytes/business-lookup-AI',
  },
  {
    title: 'NexGen — ERP with AI Task Summarization',
    description: 'Enterprise Resource Planning system built on the Frappe framework with AI-powered task summarization using Ollama. Integrates LLM capabilities into business workflow management.',
    tags: ['Python', 'Frappe', 'Ollama', 'ERP'],
    repoUrl: 'https://github.com/KaijuBytes/nexgen-public',
  },
  {
    title: 'n8n Workflow Automations',
    description: 'Collection of self-hosted n8n workflow automations running via Docker. Demonstrates workflow design, API integration, and process automation patterns.',
    tags: ['n8n', 'Docker', 'Automation'],
    repoUrl: 'https://github.com/KaijuBytes/n8n-workflows',
  },
  {
    title: 'NexHRMS — HR & Payroll System',
    description: 'Open-source Human Resource Management System with payroll processing, employee records, and attendance tracking built on the Frappe framework.',
    tags: ['Python', 'Frappe', 'HR', 'Payroll'],
    repoUrl: 'https://github.com/KaijuBytes/NexHrms',
  },
];
---

<BaseLayout title="Projects" description="Portfolio of AI, full-stack, and IoT projects by KaijuBytes.">
  <section class="py-12">
    <h1 class="text-3xl font-bold mb-4" style="color: var(--color-text);">Projects</h1>
    <p class="text-lg mb-10" style="color: var(--color-muted);">
      Production systems, open-source tools, and AI experiments. From enterprise document processing
      to IoT tracking to workflow automation.
    </p>
    <div class="grid gap-6 md:grid-cols-2">
      {projects.map(project => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>
</BaseLayout>
