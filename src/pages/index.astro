---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const featuredProjects = [
  {
    title: 'Aninaya',
    description: 'Local-first personal finance app for Filipinos. On-device AI receipt OCR, SALN module for government employees, AI Planner with optional Bring-Your-Own AI endpoint, encrypted vault export, and phone-to-phone LAN sync. Published on Google Play.',
    tags: ['Flutter', 'Drift', 'Riverpod', 'Qwen 2.5', 'On-device AI', 'Android'],
    iconUrl: '/aninaya/icon.png',
    infoUrl: '/aninaya/',
  },
  {
    title: 'IDP System',
    description: 'Enterprise RAG-based document extraction with 14-step batch pipeline, multi-provider AI (5 providers), Human-in-the-Loop review, and multi-tenant RBAC. A production proof-of-concept reached 99.95% cell-level and 99.40% row-level accuracy across ~22,000 fields on structured government forms.',
    tags: ['Python', 'FastAPI', 'React', 'PostgreSQL', 'pgvector', 'Ollama', 'Docker'],
    demoUrl: '/demos',
  },
  {
    title: 'Atlas',
    description: 'Voice + text multi-agent assistant with a 3-ring, offline-first architecture. Local wake-word, faster-whisper STT and Piper TTS, on-device Ollama for routing, a Claude/Gemini cloud tier, and vault + diary RAG via sqlite-vec.',
    tags: ['Python', 'Ollama', 'faster-whisper', 'Piper', 'sqlite-vec', 'FastAPI'],
  },
];
---

<BaseLayout title="Home" description="KaijuBytes — AI Specialist & Full-Stack Systems Engineer. Building intelligent document processing, IoT tracking, and AI-augmented systems for government and enterprise.">
  <section class="py-12 sm:py-20">
    <div class="max-w-3xl">
      <div>
      <p class="text-sm font-medium mb-4" style="color: var(--color-accent);">AI Specialist & Systems Orchestrator</p>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-6" style="color: var(--color-text);">
        Building intelligent systems<br />for government and enterprise
      </h1>
      <p class="text-lg leading-relaxed mb-8" style="color: var(--color-muted);">
        I design and deploy production AI platforms with multi-provider LLM integration,
        RAG-based document Q&A, and human-in-the-loop workflows. Full-stack development
        combined with AI-augmented systems orchestration to deliver scalable, secure automation.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/projects" class="inline-flex items-center px-6 py-3 rounded-lg text-sm font-medium transition-colors" style="background-color: var(--color-accent); color: #ffffff;">
          View Projects &rarr;
        </a>
        <a href="/demos" class="inline-flex items-center px-6 py-3 rounded-lg text-sm font-medium transition-colors" style="border: 1px solid var(--color-border); color: var(--color-text);">
          Try Live Demos
        </a>
      </div>
      </div>
    </div>
  </section>

  <section class="py-12">
    <h2 class="text-2xl font-bold mb-8" style="color: var(--color-text);">Featured Projects</h2>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {featuredProjects.map(project => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>

  <section class="py-12">
    <h2 class="text-2xl font-bold mb-6" style="color: var(--color-text);">What I Bring</h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <div class="p-5 rounded-lg" style="background-color: var(--color-surface); border: 1px solid var(--color-border);">
        <h3 class="font-semibold mb-2" style="color: var(--color-text);">AI & Document Processing</h3>
        <p class="text-sm" style="color: var(--color-muted);">Multi-provider LLM orchestration, OCR, RAG pipelines, active learning with prompt A/B testing, HITL review workflows.</p>
      </div>
      <div class="p-5 rounded-lg" style="background-color: var(--color-surface); border: 1px solid var(--color-border);">
        <h3 class="font-semibold mb-2" style="color: var(--color-text);">Full-Stack Engineering</h3>
        <p class="text-sm" style="color: var(--color-muted);">Python/FastAPI + React + PostgreSQL. Async-first architecture, raw SQL with asyncpg, WebSocket real-time updates.</p>
      </div>
      <div class="p-5 rounded-lg" style="background-color: var(--color-surface); border: 1px solid var(--color-border);">
        <h3 class="font-semibold mb-2" style="color: var(--color-text);">Infrastructure & Security</h3>
        <p class="text-sm" style="color: var(--color-muted);">Docker Compose, Kubernetes (Helm), Ansible. JWT auth, 5-role RBAC, rate limiting, Fernet encryption, audit logging.</p>
      </div>
    </div>
  </section>
</BaseLayout>
