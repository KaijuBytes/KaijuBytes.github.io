---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Blog" description="Technical writing on AI systems, document processing, and full-stack engineering.">
  <section class="py-12">
    <h1 class="text-3xl font-bold mb-4" style="color: var(--color-text);">Blog</h1>
    <p class="text-lg mb-10" style="color: var(--color-muted);">
      Technical writing on AI systems, document processing, government tech, and engineering practices.
    </p>

    <div class="p-8 rounded-xl text-center" style="background-color: var(--color-surface); border: 1px solid var(--color-border);">
      <p class="text-lg font-medium mb-2" style="color: var(--color-text);">Coming Soon</p>
      <p class="text-sm" style="color: var(--color-muted);">
        Posts on building Document AI for government, on-prem vs cloud AI cost analysis,
        and AI-augmented development workflows are in the works.
      </p>
    </div>
  </section>
</BaseLayout>
