---
interface Props {
  title: string;
  description: string;
  tags: string[];
  repoUrl?: string;
  demoUrl?: string;
  image?: string;
}

const { title, description, tags, repoUrl, demoUrl, image } = Astro.props;
---

<div class="rounded-xl p-6 transition-all hover:shadow-lg" style="background-color: var(--color-surface); border: 1px solid var(--color-border);">
  {image && (
    <img src={image} alt={title} class="w-full h-48 object-cover rounded-lg mb-4" />
  )}
  <h3 class="text-lg font-semibold mb-2" style="color: var(--color-text);">{title}</h3>
  <p class="text-sm mb-4" style="color: var(--color-muted);">{description}</p>
  <div class="flex flex-wrap gap-2 mb-4">
    {tags.map(tag => (
      <span class="text-xs px-2 py-1 rounded-full font-medium" style="background-color: var(--color-border); color: var(--color-muted);">
        {tag}
      </span>
    ))}
  </div>
  <div class="flex gap-3">
    {repoUrl && (
      <a href={repoUrl} target="_blank" rel="noopener" class="text-sm font-medium transition-colors" style="color: var(--color-accent);">
        Source Code &rarr;
      </a>
    )}
    {demoUrl && (
      <a href={demoUrl} target="_blank" rel="noopener" class="text-sm font-medium transition-colors" style="color: var(--color-accent);">
        Live Demo &rarr;
      </a>
    )}
  </div>
</div>
